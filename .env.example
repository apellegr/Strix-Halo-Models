#===============================================================================
# LLM Server Environment Configuration
#===============================================================================
# Copy this file to .env and adjust values for your system.
#   cp .env.example .env
#
# This file is sourced by start-llm-server.sh and benchmark-model.sh.
# All variables are optional -- sensible defaults are used when unset.
# Uncomment and modify only the variables you need to override.
#===============================================================================

#-------------------------------------------------------------------------------
# Paths
#-------------------------------------------------------------------------------

# Directory containing downloaded GGUF model files
#MODELS_DIR="./models"

# Directory for runtime files (PIDs, port locks, logs)
#RUN_DIR="$HOME/.llm-servers"

# Directory where benchmark results are written
#RESULTS_DIR="./benchmarks"

# Path to the optimized model-configurations JSON file
#CONFIG_FILE="./model-configs.json"

#-------------------------------------------------------------------------------
# llama.cpp Binaries
#-------------------------------------------------------------------------------
# Point these at your compiled (or installed) llama.cpp binaries.

# llama-server binary
#LLAMA_SERVER="$HOME/.local/bin/llama-server"

# llama-bench binary (used by benchmark-model.sh)
#LLAMA_BENCH="$HOME/.local/bin/llama-bench"

# llama-cli binary
#LLAMA_CLI="$HOME/.local/bin/llama-cli"

#-------------------------------------------------------------------------------
# Server Defaults
#-------------------------------------------------------------------------------

# Network interface to bind to (0.0.0.0 = all interfaces)
#DEFAULT_HOST="0.0.0.0"

# TCP port for the llama-server HTTP API
#DEFAULT_PORT="8081"

# Number of CPU threads (match your physical core count)
#DEFAULT_THREADS="16"

# Prompt-processing batch size
#DEFAULT_BATCH_SIZE="512"

# Default KV-cache context length
#DEFAULT_CTX_SIZE="4096"

#-------------------------------------------------------------------------------
# ROCm / GPU Settings (AMD APUs with Unified Memory)
#-------------------------------------------------------------------------------
# These environment variables control how ROCm allocates VRAM on APUs
# (e.g., AMD Strix Halo). Uncomment if GPU offloading is not working
# or you need to raise memory limits.

# Disable SDMA engine (required on some APU firmware versions)
#HSA_ENABLE_SDMA=0

# Allow the GPU runtime to use up to 100% of reported heap
#GPU_MAX_HEAP_SIZE=100
#GPU_MAX_ALLOC_PERCENT=100
#GPU_SINGLE_ALLOC_PERCENT=100

# Force 64-bit pointers for large allocations
#GPU_FORCE_64BIT_PTR=1

# Select which GPU device index to use
#HIP_VISIBLE_DEVICES=0

# Override the GFX ISA version reported to the compiler/runtime
#HSA_OVERRIDE_GFX_VERSION=11.5.1
